# ══════════════════════════════════════════════════════════
#   ShieldGuard .env — Complete Config
#   Total cost: ₹0/month
#   IMPORTANT: Add this file to .gitignore!
# ══════════════════════════════════════════════════════════

# ── API Keys (Free — get from URLs below) ─────────────────

# Groq API — console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE

# HuggingFace — huggingface.co → Settings → Access Tokens → Read
HF_TOKEN=hf_YOUR_HF_TOKEN_HERE

# ── Local Model Names (auto-download once) ─────────────────

IMAGE_MODEL=prithivMLmods/AI-vs-Deepfake-vs-Real-Siglip2
TEXT_MODEL=cybersectony/phishing-email-detection-distilbert_v2.4.1
HINDI_MODEL=ai4bharat/indic-bert
STT_MODEL=vasista22/whisper-hindi-small
STT_FALLBACK=collabora/whisper-tiny-hindi
TTS_MODEL=facebook/mms-tts-hin
SHIELD_MODEL=google/shieldgemma-2b

# ── App Config ─────────────────────────────────────────────

API_PORT=8001
DB_URL=sqlite:///./shieldguard.db
LOG_RAW_TEXT=False
RATE_LIMIT=30/minute

# ShieldCall config
OTP_CUTOFF_COUNT=2
VISHING_CRITICAL_SCORE=75
CALL_WARN_SCORE=40

# ── NVIDIA NIM (optional, kept for compatibility) ──────────
# NVIDIA_NIM_API_KEY=nvapi_YOUR_KEY_HERE  # Not needed — using Groq instead
